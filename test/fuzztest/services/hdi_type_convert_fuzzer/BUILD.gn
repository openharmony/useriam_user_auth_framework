import("//build/ohos.gni")
import("//build/test.gni")

ohos_fuzztest("HdiTypeConvertFuzzTest") {
  branch_protector_ret = "pac_ret"
  module_out_path = "user_auth_framework/user_auth/concurrent"
  fuzz_config_file = "../hdi_type_convert_fuzzer"

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  include_dirs = [
    "../../../../services/engine/inc",
    "../../../../services/engine/pub_inc",
    "../../../../common/test",
    "../../../../common/logs",
    "../../../../interfaces/inner_api",
  ]

  sources = [
    "../../../../services/engine/src/hdi_type_convert.cpp",
    "hdi_type_convert_fuzzer.cpp",
  ]

  remove_configs = [ "//build/config/compiler:no_exceptions" ]

  configs = [
    "../../../../common:iam_log_config",
    "../../../../common:iam_utils_config",
    "../../../../frameworks/native/ipc:userauth_client_ipc_config",
  ]

  deps = [ "../../common_fuzzer:iam_test_fuzzer" ]

  external_deps = [
    "access_token:libaccesstoken_sdk",
    "c_utils:utils",
    "drivers_interface_user_auth:libuser_auth_proxy_4.0",
    "drivers_interface_user_auth:libuser_auth_proxy_4.1",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]

  subsystem_name = "useriam"
  part_name = "user_auth_framework"
}
